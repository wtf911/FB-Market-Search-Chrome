{
  "manifest_version": 3,
  "name": "Marketplace Description Search (free)",
  "version": "1.8.5",
  "description": "Search Facebook Marketplace by words in the listing DESCRIPTION, with scheduled keyword alerts.",
  "permissions": ["scripting", "tabs", "storage", "alarms", "notifications"],
  "host_permissions": ["*://*.facebook.com/*"],
  "background": { "service_worker": "background.js" },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Marketplace Description Alerts",
    "default_icon": { "16": "icon16.png", "48": "icon48.png", "128": "icon128.png" }
  },
  "icons": { "16": "icon16.png", "48": "icon48.png", "128": "icon128.png" },
  "content_scripts": [
    {
      "matches": ["*://*.facebook.com/*"],
      "js": ["content.js"],
      "css": ["panel.css"],
      "run_at": "document_idle"
    }
  ]
}
